CREATE TABLE KnowledgeBase (
    id TEXT PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    description TEXT,
    created_at TEXT NOT NULL,
    updated_at TEXT NOT NULL,
    version INTEGER NOT NULL DEFAULT 1,
    deleted_at TEXT,
    synced_at TEXT
);

CREATE TABLE Deck (
    id TEXT PRIMARY KEY NOT NULL,
    knowledge_base_id TEXT NOT NULL,
    name TEXT NOT NULL,
    description TEXT,
    color TEXT DEFAULT '#4CAF50',
    icon TEXT DEFAULT '📚',
    parent_id TEXT,
    created_at TEXT NOT NULL,
    updated_at TEXT NOT NULL,
    version INTEGER NOT NULL DEFAULT 1,
    deleted_at TEXT,
    synced_at TEXT,
    FOREIGN KEY (knowledge_base_id) REFERENCES KnowledgeBase(id),
    FOREIGN KEY (parent_id) REFERENCES Deck(id)
);

CREATE TABLE Card (
    id TEXT PRIMARY KEY NOT NULL,
    deck_id TEXT NOT NULL,
    type TEXT NOT NULL,
    front TEXT NOT NULL,
    back TEXT NOT NULL,
    tags TEXT DEFAULT '[]',
    media TEXT DEFAULT '[]',
    metadata TEXT DEFAULT '{}',
    created_at TEXT NOT NULL,
    updated_at TEXT NOT NULL,
    last_reviewed_at TEXT,
    next_review_at TEXT,
    version INTEGER NOT NULL DEFAULT 1,
    deleted_at TEXT,
    synced_at TEXT,
    FOREIGN KEY (deck_id) REFERENCES Deck(id)
);

CREATE TABLE ReviewLog (
    id TEXT PRIMARY KEY NOT NULL,
    card_id TEXT NOT NULL,
    rating INTEGER NOT NULL,
    review_time INTEGER NOT NULL,
    interval INTEGER NOT NULL,
    ease_factor REAL NOT NULL,
    repetitions INTEGER NOT NULL,
    lapse_count INTEGER NOT NULL,
    reviewed_at TEXT NOT NULL,
    version INTEGER NOT NULL DEFAULT 1,
    deleted_at TEXT,
    synced_at TEXT,
    FOREIGN KEY (card_id) REFERENCES Card(id)
);

CREATE TABLE AppSettings (
    key TEXT PRIMARY KEY NOT NULL,
    setting_value TEXT NOT NULL
);

CREATE TABLE AlgorithmState (
    card_id TEXT PRIMARY KEY NOT NULL,
    mode TEXT NOT NULL,
    state_json TEXT NOT NULL,
    FOREIGN KEY (card_id) REFERENCES Card(id)
);

CREATE TABLE LearningPlan (
    id TEXT PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    description TEXT,
    status TEXT NOT NULL DEFAULT 'NOT_STARTED',
    is_default INTEGER NOT NULL DEFAULT 0,
    knowledge_base_ids TEXT DEFAULT '[]',
    deck_ids TEXT DEFAULT '[]',
    card_ids TEXT DEFAULT '[]',
    total_cards INTEGER NOT NULL DEFAULT 0,
    completed_cards INTEGER NOT NULL DEFAULT 0,
    created_at TEXT NOT NULL,
    updated_at TEXT NOT NULL,
    version INTEGER NOT NULL DEFAULT 1,
    deleted_at TEXT,
    synced_at TEXT
);

selectAllKnowledgeBases:
SELECT * FROM KnowledgeBase WHERE deleted_at IS NULL ORDER BY created_at ASC;

selectKnowledgeBaseById:
SELECT * FROM KnowledgeBase WHERE id = ?;

selectKnowledgeBaseByName:
SELECT * FROM KnowledgeBase WHERE name = ? AND deleted_at IS NULL;

selectAllDecks:
SELECT * FROM Deck WHERE deleted_at IS NULL ORDER BY created_at ASC;

selectDecksByKnowledgeBase:
SELECT * FROM Deck WHERE knowledge_base_id = ? AND deleted_at IS NULL ORDER BY created_at ASC;

selectDeckById:
SELECT * FROM Deck WHERE id = ?;

selectDeckByNameAndKnowledgeBase:
SELECT * FROM Deck WHERE knowledge_base_id = ? AND name = ? AND deleted_at IS NULL;

selectAllCards:
SELECT * FROM Card WHERE deleted_at IS NULL ORDER BY created_at ASC;

selectCardsByDeck:
SELECT * FROM Card WHERE deck_id = ? AND deleted_at IS NULL ORDER BY created_at ASC;

selectCardById:
SELECT * FROM Card WHERE id = ?;

selectDueCards:
SELECT * FROM Card WHERE deleted_at IS NULL AND next_review_at IS NOT NULL AND next_review_at <= ? ORDER BY next_review_at ASC;

insertKnowledgeBase:
INSERT OR REPLACE INTO KnowledgeBase(id, name, description, created_at, updated_at, version, deleted_at, synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

updateKnowledgeBase:
UPDATE KnowledgeBase SET name = ?, description = ?, updated_at = ?, version = version + 1, deleted_at = ?, synced_at = ? WHERE id = ?;

insertDeck:
INSERT OR REPLACE INTO Deck(id, knowledge_base_id, name, description, color, icon, parent_id, created_at, updated_at, version, deleted_at, synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateDeck:
UPDATE Deck SET name = ?, description = ?, color = ?, icon = ?, parent_id = ?, updated_at = ?, version = version + 1, deleted_at = ?, synced_at = ? WHERE id = ?;

insertCard:
INSERT OR REPLACE INTO Card(id, deck_id, type, front, back, tags, media, metadata, created_at, updated_at, last_reviewed_at, next_review_at, version, deleted_at, synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

insertReviewLog:
INSERT OR REPLACE INTO ReviewLog(id, card_id, rating, review_time, interval, ease_factor, repetitions, lapse_count, reviewed_at, version, deleted_at, synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateCard:
UPDATE Card SET deck_id = ?, type = ?, front = ?, back = ?, tags = ?, media = ?, metadata = ?, updated_at = ?, last_reviewed_at = ?, next_review_at = ?, version = version + 1
WHERE id = ?;

softDeleteCard:
UPDATE Card SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE id = ?;

softDeleteCardsByDeck:
UPDATE Card SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE deck_id = ? AND deleted_at IS NULL;

softDeleteDecksByKnowledgeBase:
UPDATE Deck SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE knowledge_base_id = ? AND deleted_at IS NULL;

softDeleteCardsByKnowledgeBase:
UPDATE Card SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE deck_id IN (SELECT id FROM Deck WHERE knowledge_base_id = ?) AND deleted_at IS NULL;

softDeleteDeck:
UPDATE Deck SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE id = ?;

softDeleteKnowledgeBase:
UPDATE KnowledgeBase SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE id = ?;

softDeleteReviewLog:
UPDATE ReviewLog SET deleted_at = ?, version = version + 1, synced_at = NULL WHERE id = ?;

softDeleteLearningPlan:
UPDATE LearningPlan SET deleted_at = ?, updated_at = ?, version = version + 1, synced_at = NULL WHERE id = ?;

-- Compiled-time stub: replaced with FTS5 virtual table at runtime (see DatabaseDriverFactory).
CREATE TABLE IF NOT EXISTS CardFTS(
    card_id TEXT NOT NULL,
    front TEXT NOT NULL,
    back TEXT NOT NULL,
    tags TEXT NOT NULL
);

insertCardFts:
INSERT INTO CardFTS(card_id, front, back, tags) VALUES (?, ?, ?, ?);

deleteCardFts:
DELETE FROM CardFTS WHERE card_id = ?;

deleteAllCardFts:
DELETE FROM CardFTS;

rebuildCardFts:
INSERT INTO CardFTS(card_id, front, back, tags) SELECT id, front, back, tags FROM Card WHERE deleted_at IS NULL;

searchCards:
SELECT * FROM Card WHERE deleted_at IS NULL AND (front LIKE '%' || ? || '%' OR back LIKE '%' || ? || '%' OR tags LIKE '%' || ? || '%');

selectAllReviewLogs:
SELECT * FROM ReviewLog WHERE deleted_at IS NULL ORDER BY reviewed_at DESC;

selectReviewLogsByCardId:
SELECT * FROM ReviewLog WHERE card_id = ? AND deleted_at IS NULL ORDER BY reviewed_at DESC;

selectSetting:
SELECT * FROM AppSettings WHERE key = ?;

selectAllSettings:
SELECT * FROM AppSettings;

insertSetting:
INSERT OR REPLACE INTO AppSettings(key, setting_value)
VALUES (?, ?);

deleteSetting:
DELETE FROM AppSettings WHERE key = ?;

selectAlgorithmState:
SELECT * FROM AlgorithmState WHERE card_id = ?;

selectAllAlgorithmStates:
SELECT * FROM AlgorithmState;

insertAlgorithmState:
INSERT OR REPLACE INTO AlgorithmState(card_id, mode, state_json)
VALUES (?, ?, ?);

deleteAlgorithmState:
DELETE FROM AlgorithmState WHERE card_id = ?;

selectAllLearningPlans:
SELECT * FROM LearningPlan WHERE deleted_at IS NULL ORDER BY updated_at DESC;

selectLearningPlanById:
SELECT * FROM LearningPlan WHERE id = ?;

selectDefaultLearningPlan:
SELECT * FROM LearningPlan WHERE is_default = 1 AND deleted_at IS NULL;

insertLearningPlan:
INSERT OR REPLACE INTO LearningPlan(id, name, description, status, is_default, knowledge_base_ids, deck_ids, card_ids, total_cards, completed_cards, created_at, updated_at, version, deleted_at, synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateLearningPlan:
UPDATE LearningPlan SET name = ?, description = ?, status = ?, is_default = ?, knowledge_base_ids = ?, deck_ids = ?, card_ids = ?, total_cards = ?, completed_cards = ?, updated_at = ?, version = version + 1, deleted_at = ?, synced_at = ? WHERE id = ?;

-- Incremental sync queries
selectKnowledgeBasesUpdatedSince:
SELECT * FROM KnowledgeBase WHERE (synced_at IS NULL OR updated_at > ?) AND deleted_at IS NULL;

selectDecksUpdatedSince:
SELECT * FROM Deck WHERE (synced_at IS NULL OR updated_at > ?) AND deleted_at IS NULL;

selectCardsUpdatedSince:
SELECT * FROM Card WHERE (synced_at IS NULL OR updated_at > ?) AND deleted_at IS NULL;

selectReviewLogsUpdatedSince:
SELECT * FROM ReviewLog WHERE (synced_at IS NULL OR reviewed_at > ?) AND deleted_at IS NULL;

selectLearningPlansUpdatedSince:
SELECT * FROM LearningPlan WHERE (synced_at IS NULL OR updated_at > ?) AND deleted_at IS NULL;

updateKnowledgeBaseSyncedAt:
UPDATE KnowledgeBase SET synced_at = ? WHERE id = ?;

updateDeckSyncedAt:
UPDATE Deck SET synced_at = ? WHERE id = ?;

updateCardSyncedAt:
UPDATE Card SET synced_at = ? WHERE id = ?;

updateReviewLogSyncedAt:
UPDATE ReviewLog SET synced_at = ? WHERE id = ?;

updateLearningPlanSyncedAt:
UPDATE LearningPlan SET synced_at = ? WHERE id = ?;

-- Media sync cache (Anki-style: track mtime + sha1 to avoid re-hashing)
CREATE TABLE IF NOT EXISTS MediaCache (
    path TEXT PRIMARY KEY NOT NULL,
    mtime INTEGER NOT NULL,
    sha1 TEXT NOT NULL,
    synced_at TEXT
);

selectMediaCache:
SELECT * FROM MediaCache WHERE path = ?;

selectAllMediaCache:
SELECT * FROM MediaCache;

insertMediaCache:
INSERT OR REPLACE INTO MediaCache(path, mtime, sha1, synced_at) VALUES (?, ?, ?, ?);

deleteMediaCache:
DELETE FROM MediaCache WHERE path = ?;

deleteAllMediaCache:
DELETE FROM MediaCache;
